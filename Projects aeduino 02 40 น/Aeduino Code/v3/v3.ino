void setup() {
  Serial.begin(115200);

  // สำหรับ ESP8266 D1 Mini: SDA = D2, SCL = D1
  Wire.begin(SDA, SCL);
  //Wire.begin(2, 3); 

  // เริ่มต้นจอ OLED (ที่อยู่ 0x3C)
  if (!display.begin(0x3c, true)) {
    Serial.println(F("OLED FAIL"));
    for (;;);
  }

  display.clearDisplay();
  display.setTextColor(SH110X_WHITE);

  // เริ่มต้น RTC
  if (rtc.begin()) {
    rtc_ok = true;
    Serial.println(F("RTC OK"));
    
    // ถ้าเวลาไม่ตรง ให้เอาคอมเมนต์ออกแล้วเบิร์น 1 รอบ จากนั้นคอมเมนต์กลับแล้วเบิร์นซ้ำ
    // rtc.adjust(DateTime(F(__DATE__), F(__TIME__)));
  } else {
    rtc_ok = false;
    Serial.println(F("RTC NOT FOUND"));
  }

  display.setTextSize(1);
  display.setCursor(35, 30);
  display.print("SYSTEM READY");
  display.display();
  delay(1500);
}

void loop() {
  bool isOpen = true; // Default เป็นเปิดหากหา RTC ไม่เจอ

  if (rtc_ok) {
    DateTime now = rtc.now();
    int hour = now.hour();
    int minute = now.minute();

    // เงื่อนไขเวลา: เปิด 06:00 - 07:45
    if (hour < 6) {
       isOpen = false;
      } else if (hour == 7 && minute > 45) {
      isOpen = false;
    } else if (hour > 7) {
      isOpen = false;
    } else {
      isOpen = true;
    }

    // Debug ผ่าน Serial Monitor
    Serial.printf("Current Time: %02d:%02d Status: %s\n", hour, minute, isOpen ? "OPEN" : "CLOSED");
  }

  display.clearDisplay();

  if (isOpen) {
    // แสดง QR Code
    display.drawBitmap(0, 0, qr1, 128, 64, SH110X_WHITE);
  } else {
    // แสดงข้อความเมื่อปิดระบบ
    display.setTextSize(2);
    display.setCursor(35, 25);
    display.print("CLOSE");
  }

  display.display();
  delay(1000);
}